GOOGLE_CLIENT_ID=          # Google OAuth client ID
GOOGLE_CLIENT_SECRET=      # Google OAuth client secret
NEXTAUTH_SECRET=           # Random secret for JWT signing (generate with: openssl rand -base64 32)
NEXTAUTH_URL=              # Base URL (e.g., https://tseda.tce.edu or http://localhost:3000)

# Optional
CRON_SECRET=               # Shared secret for /api/cron/nightly (if blank, cron endpoint is disabled)
DATA_ROOT=                 # Custom data directory (default: .data)
DATA_BACKUP_ROOT=          # Custom backup directory (default: .data/backups)
LOG_LEVEL=                 # Logging level: debug | info | warn | error (default: info in production, debug in dev)
