# =============================================================================
# Production Environment Variables
# Copy to .env.local and fill in actual values before deploying.
# =============================================================================

# --- Google OAuth (required) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth (required) ---
NEXTAUTH_SECRET=          # Generate with: openssl rand -base64 32
NEXTAUTH_URL=https://your-domain.tce.edu

# --- Application ---
NODE_ENV=production
DATA_ROOT=.data           # Path to file-based data storage
LOG_LEVEL=info            # debug | info | warn | error

# --- Optional ---
# PORT=3000               # Server port (default: 3000)
