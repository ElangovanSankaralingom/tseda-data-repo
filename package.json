{
  "name": "tseda-data-repo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true npm run build",
    "lint": "eslint",
    "typecheck": "sh -c 'next build >/dev/null && npx tsc -p tsconfig.json --noEmit'",
    "test": "NODE_ENV=test node --test --experimental-strip-types --experimental-loader ./tests/helpers/pathAliasLoader.mjs tests/**/*.test.ts",
    "test:coverage": "NODE_ENV=test c8 --reporter=text --reporter=html --reporter=lcov node --test --experimental-strip-types --experimental-loader ./tests/helpers/pathAliasLoader.mjs tests/**/*.test.ts",
    "test:ci": "NODE_ENV=test c8 --check-coverage --lines 50 --functions 45 --branches 40 --reporter=text --reporter=lcov node --test --experimental-strip-types --experimental-loader ./tests/helpers/pathAliasLoader.mjs tests/**/*.test.ts",
    "migrate:data": "node --experimental-strip-types scripts/migrate-data.ts",
    "backup:data": "node --experimental-strip-types scripts/backup-data.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "pdf-lib": "^1.17.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "c8": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
